{
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "packages/*/extensions/**/*.ts",
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts"
  ],
  "exclude": ["node_modules", "**/node_modules"]
}
